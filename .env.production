# Production Environment (Full Remote)
# Usage: docker compose --env-file .env.production up --build

# Public URLs (Client-Side) - Baked at Build Time
NEXT_PUBLIC_API_URL=https://openstream.octanebrew.dev/api
NEXT_PUBLIC_SOCKET_URL=wss://openstream.octanebrew.dev/ingest
NEXT_PUBLIC_RTMP_URL=rtmp://openstream.octanebrew.dev/live

# Internal URLs (Server-Side) - Runtime Injection
# Points to the internal Docker container on 'octane-net'
INTERNAL_API_URL=http://openstream-api:4000/api
INTERNAL_SOCKET_URL=ws://openstream-api:4000/ingest
